# server/.env
# TODO: Replace with your MongoDB Atlas connection string
MONGODB_URI=your_mongodb_atlas_connection_string

# TODO: Replace with a long random JWT secret
JWT_SECRET=your_super_secret_jwt_key

# TODO: Replace with your OpenRouter API key from deployment secret manager
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_NAME=AI Trip Planner

# TODO: Replace with your Google OAuth credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Frontend URL used for OAuth and AI provider referer metadata
CLIENT_URL=http://localhost:5173

# Comma-separated allowlist for CORS (include deployed frontend origin)
# Example: CLIENT_URLS=https://your-frontend.vercel.app,http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:5178
CORS_ALLOW_LOCALHOST=true
SERVER_URL=http://localhost:5000
PORT=5000
